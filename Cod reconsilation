function handleBulkFile(input) { if (input.files.length) parseBulkFile(input.files[0]); }

async function parseBulkFile(file) {
  addFileItem('bulk-orders', file.name, 'loading', 'Parsing...');
  try {
    const ext = file.name.split('.').pop().toLowerCase();
    let rawRows = ext === 'csv' || ext === 'txt' ? await parseCSV(file,'bulk') : await parseXLSX(file,'bulk');
    let headerIdx = 0;
    for (let i = 0; i < Math.min(5, rawRows.length); i++) {
      if (rawRows[i].join(' ').toLowerCase().includes('order id') || rawRows[i].join(' ').toLowerCase().includes('voucher')) { headerIdx = i; break; }
    }
    const headers = rawRows[headerIdx].map(h => String(h||'').trim());
    const dataRows = rawRows.slice(headerIdx+1).filter(r => r.some(c => c !== '' && c !== null));
    const ci = { platform:0, date:1, orderid:4, email:10, amount:15 };
    headers.forEach((h,i) => {
      const n = h.toLowerCase();
      if (n.includes('order id')) ci.orderid = i;
      if (n.includes('selling amount') || n === 'selling amount') ci.amount = i;
      if (n.includes('email')) ci.email = i;
      if (n === 'date') ci.date = i;
    });
    const orderMap = {}; let skipped = 0;
    dataRows.forEach(row => {
      const platRaw = String(row[ci.platform]||'').trim().toUpperCase();
      const platform = PLATFORM_MAP[platRaw];
      if (!platform) { skipped++; return; }
      const orderId = String(row[ci.orderid]||'').trim();
      if (!orderId) { skipped++; return; }
      const amount = parseFloat(String(row[ci.amount]||'0').replace(/[^0-9.-]/g,'')) || 0;
      const email = String(row[ci.email]||'').trim().toLowerCase();
      const date = parseDate(row[ci.date]);
      const key = platform+'::'+orderId;
      if (!orderMap[key]) orderMap[key] = { platform, order_id:orderId, order_date:date, email, sale_amount:0, payment_type:'COD', status:'pending' };
      orderMap[key].sale_amount += amount;
    });
    const records = Object.values(orderMap);
    const platCounts = {};
    records.forEach(r => { platCounts[r.platform] = (platCounts[r.platform]||0)+1; });
    _bulkParsed = { records, platCounts, fileName: file.name };
    const platHtml = Object.entries(platCounts).map(([p,c]) => `${platBadge(p)} <b>${c}</b>`).join(' &nbsp; ');
    document.getElementById('bulkPreviewInfo').innerHTML =
      `✅ <b>${records.length} unique orders</b> (${skipped} rows skipped)<br>${platHtml}`;
    document.getElementById('bulkPreview').style.display = 'block';
    addFileItem('bulk-orders', file.name, 'ok', records.length+' orders ready');
  } catch(err) { addFileItem('bulk-orders', file.name, 'err', err.message); showToast('Error: '+err.message,'error'); }
}
function cancelBulkUpload() {
  _bulkParsed = null;
  document.getElementById('bulkPreview').style.display = 'none';
  document.getElementById('bulkOrderInput').value = '';
  document.getElementById('fl-bulk-orders').innerHTML = '';
}
async function confirmBulkUpload() {
  if (!_bulkParsed) return;
  const { records, fileName } = _bulkParsed;
  document.getElementById('bulkPreview').style.display = 'none';
  addFileItem('bulk-orders', fileName, 'loading', 'Uploading...');
  try {
    let imported = 0;
    for (let i = 0; i < records.length; i += 200) {
      const { error } = await db.from('cod_orders').upsert(records.slice(i,i+200), { onConflict:'platform, order_id', ignoreDuplicates:false });
      if (error) throw error;
      imported += Math.min(200, records.length-i);
    }
    await db.from('cod_upload_log').insert({ platform:'bulk', file_name:fileName, upload_type:'orders', rows_imported:imported });
    addFileItem('bulk-orders', fileName, 'ok', imported+' orders imported');
    showToast('✅ '+imported+' orders import ho gaye!','success');
    _bulkParsed = null;
    loadDashboard();
  } catch(err) { addFileItem('bulk-orders', fileName, 'err', err.message); showToast('Import failed: '+err.message,'error'); }
}

// ── FILE PROCESSING (settlement) ─────────────────────────────
const settleFields = [
  {key:'order_id',label:'Order ID',required:true},
  {key:'settled_amount',label:'Settled Amount (₹)',required:true},
  {key:'settlement_date',label:'Settlement Date',required:false},
  {key:'settlement_id',label:'Settlement ID',required:false},
  {key:'utr_number',label:'UTR Number',required:false},
];

async function processFileUpload(file, platform, type) {
  const key = platform+'-settle';
  addFileItem(key, file.name, 'loading', 'Parsing...');
  try {
    const ext = file.name.split('.').pop().toLowerCase();
    let rows = ext==='csv'||ext==='txt' ? await parseCSV(file,platform) : await parseXLSX(file,platform);
    if (!rows || rows.length < 2) throw new Error('File empty ya sirf header hai');
    const headers = rows[0]; const dataRows = rows.slice(1).filter(r => r.some(c => c!==''&&c!==null));
    pendingMapping = { platform, type, rows:dataRows, columns:headers, fileName:file.name };
    showMappingModal(platform, type, headers, dataRows[0]);
    addFileItem(key, file.name, 'loading', 'Column mapping...');
  } catch(err) { addFileItem(key, file.name, 'err', err.message); showToast('Error: '+err.message,'error'); }
}

function showMappingModal(platform, type, headers, sampleRow) {
  document.getElementById('mappingTitle').textContent = 'Column Mapping – '+platform.toUpperCase()+' settlement';
  const guess = autoGuessMapping(headers, platform);
  const norm = headers.map(h => (h||'').toString());
  let html = '<div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;font-size:13px;"><thead><tr>';
  html += '<th style="padding:8px;border-bottom:2px solid var(--border);text-align:left;font-size:12px;">Field</th>';
  html += '<th style="padding:8px;border-bottom:2px solid var(--border);text-align:left;font-size:12px;">File Column</th>';
  html += '<th style="padding:8px;border-bottom:2px solid var(--border);text-align:left;font-size:12px;">Sample</th>';
  html += '</tr></thead><tbody>';
  settleFields.forEach(f => {
    html += `<tr><td style="padding:8px;border-bottom:1px solid var(--cream2);">${f.label}${f.required?' <span style="color:var(--red)">*</span>':''}</td>`;
    html += `<td style="padding:8px;border-bottom:1px solid var(--cream2);">`;
    html += `<select id="map-${f.key}" class="filter-select" style="width:100%;"><option value="">-- Skip --</option>`;
    norm.forEach((h,i) => { html += `<option value="${i}"${guess[f.key]===i?' selected':''}>${h||'Col '+(i+1)}</option>`; });
    html += `</select></td>`;
    html += `<td style="padding:8px;border-bottom:1px solid var(--cream2);color:var(--text2);font-size:12px;" id="sample-${f.key}">${guess[f.key]!==undefined?(sampleRow[guess[f.key]]||'—'):'—'}</td></tr>`;
  });
  html += '</tbody></table></div>';
  document.getElementById('mappingFields').innerHTML = html;
  settleFields.forEach(f => {
    const sel = document.getElementById('map-'+f.key);
    sel.addEventListener('change', () => {
      const idx = parseInt(sel.value);
      document.getElementById('sample-'+f.key).textContent = (!isNaN(idx)&&sampleRow[idx]!==undefined)?(sampleRow[idx]||'—'):'—';
    });
  });
  document.getElementById('mappingModal').classList.add('open');
}

function autoGuessMapping(headers, platform) {
  const guess = {}; const norm = headers.map(h => (h||'').toString().toLowerCase().replace(/[^a-z0-9]/g,' ').trim());
  if (platform==='bluedart') {
    const f=kw=>norm.findIndex(n=>n.includes(kw));
    const a=f('awbno'); if(a>=0) guess.order_id=a;
    const am=f('amount'); if(am>=0) guess.settled_amount=am;
    const d=f('deposit date'); if(d>=0) guess.settlement_date=d;
    const u=f('bank pay ref'); if(u>=0) guess.utr_number=u;
    return guess;
  }
  if (platform==='billdesk') {
    const f=kw=>norm.findIndex(n=>n.includes(kw));
    const p=f('pgi ref'); if(p>=0) guess.order_id=p;
    // For BillDesk we also try email (Ref.3) as order_id
    const r3=norm.findIndex((n,i)=>headers[i]&&headers[i].toString().includes('Ref. 3'));
    if(r3>=0) guess.order_id=r3;
    const na=f('net amount'); if(na>=0) guess.settled_amount=na;
    const sd=f('settlement date'); if(sd>=0) guess.settlement_date=sd;
    const b=f('bank ref'); if(b>=0) guess.utr_number=b;
    return guess;
  }
  if (platform==='delhivery') {
    const f=kw=>norm.findIndex(n=>n.includes(kw));
    const w=f('waybill'); if(w>=0) guess.order_id=w;
    const c=f('cod amount'); if(c>=0) guess.settled_amount=c;
    const d=f('delivered date'); if(d>=0) guess.settlement_date=d;
    return guess;
  }
  if (platform==='zippie') {
    const f=kw=>norm.findIndex(n=>n.includes(kw));
    const a=f('awb number'); if(a>=0) guess.order_id=a;
    const v=f('total value'); if(v>=0) guess.settled_amount=v;
    const d=f('actual delivery'); if(d>=0) guess.settlement_date=d;
    return guess;
  }
  if (platform==='snapmint') {
    const f=kw=>norm.findIndex(n=>n.includes(kw));
    const s=f('shopify order'); if(s>=0) guess.order_id=s; else { const o=f('order no'); if(o>=0) guess.order_id=o; }
    const sv=f('settlement value'); if(sv>=0) guess.settled_amount=sv;
    const u=f('utr'); if(u>=0) guess.utr_number=u;
    const sr=f('settlement reference'); if(sr>=0) guess.settlement_id=sr;
    return guess;
  }
  // generic
  const m={order_id:['order id','order no','awbno','pgi ref'],settled_amount:['net amount','settled amount','settlement value','cod amount','amount'],settlement_date:['settlement date','deposit date','transfer date'],settlement_id:['settlement id','settlement reference'],utr_number:['utr','bank pay ref','bank ref']};
  Object.entries(m).forEach(([field,kws])=>{for(let i=0;i<norm.length;i++){if(kws.some(k=>norm[i].includes(k)||k.includes(norm[i]))){guess[field]=i;break;}}});
  return guess;
}

function closeMappingModal() { document.getElementById('mappingModal').classList.remove('open'); pendingMapping=null; }

async function confirmMapping() {
  if (!pendingMapping) return;
  const { platform, type, rows, fileName } = pendingMapping;
  const mapping = {}; let valid = true;
  settleFields.forEach(f => {
    const val = document.getElementById('map-'+f.key)?.value;
    if (f.required && !val) { showToast(f.label+' required hai!','error'); valid=false; }
    mapping[f.key] = val!==''?parseInt(val):null;
  });
  if (!valid) return;
  closeMappingModal();
  const key = platform+'-settle';
  try {
    const batchId = platform+'-'+Date.now();
    const records = [];
    rows.forEach(row => {
      const orderId = mapping.order_id!==null ? String(row[mapping.order_id]||'').trim() : '';
      const amount = mapping.settled_amount!==null ? parseFloat(String(row[mapping.settled_amount]||'0').replace(/[^0-9.-]/g,'')) : 0;
      if (!orderId || isNaN(amount)) return;
      records.push({
        platform, order_id:orderId,
        settled_amount: amount,
        settlement_date: mapping.settlement_date!==null ? parseDate(row[mapping.settlement_date]) : null,
        settlement_id: mapping.settlement_id!==null ? String(row[mapping.settlement_id]||'').trim()||null : null,
        utr_number: mapping.utr_number!==null ? String(row[mapping.utr_number]||'').trim()||null : null,
        upload_batch: batchId
      });
    });
    if (!records.length) throw new Error('No valid rows found');
    let imported = 0;
    for (let i=0;i<records.length;i+=200) {
      const { error } = await db.from('cod_settlements').upsert(records.slice(i,i+200),{onConflict:'platform, order_id, settlement_id',ignoreDuplicates:false});
      if (error) throw error;
      imported += Math.min(200, records.length-i);
    }
    await db.from('cod_upload_log').insert({platform,file_name:fileName,upload_type:'settlement',rows_imported:imported});
    addFileItem(key, fileName, 'ok', imported+' rows imported');
    showToast('✅ '+imported+' rows import ho gaye – '+platform,'success');
    loadDashboard();
  } catch(err) { addFileItem(key, fileName, 'err', err.message); showToast('Import failed: '+err.message,'error'); }
}

// ── PARSE ─────────────────────────────────────────────────────
function parseCSV(file, platform) {
  return new Promise((res,rej) => {
    const reader = new FileReader();
    reader.onload = e => {
      try {
        let text = e.target.result;
        if (platform==='bluedart') {
          const lines = text.split('\n').map(l=>l.trim()).filter(l=>l);
          const hi = lines.findIndex(l=>l.includes('AWBNO#'));
          if (hi<0) { rej(new Error('Bluedart format nahi mila — AWBNO# column missing')); return; }
          const parsed = lines.slice(hi).filter(l=>!l.startsWith('---')).map(l=>l.split(',').map(c=>c.trim()));
          res(parsed); return;
        }
        Papa.parse(text,{skipEmptyLines:true,complete:r=>res(r.data),error:e=>rej(e)});
      } catch(err){rej(err);}
    };
    reader.onerror=rej; reader.readAsText(file);
  });
}
function parseXLSX(file, platform) {
  return new Promise((res,rej) => {
    const reader = new FileReader();
    reader.onload = e => {
      try {
        const wb = XLSX.read(e.target.result,{type:'binary',cellDates:false});
        const ws = wb.Sheets[wb.SheetNames[0]];
        if (platform==='billdesk') {
          const raw = XLSX.utils.sheet_to_json(ws,{header:1,defval:'',range:1});
          res(raw.filter(r=>r.some(c=>c!==''))); return;
        }
        res(XLSX.utils.sheet_to_json(ws,{header:1,defval:''}));
      } catch(err){rej(err);}
    };
    reader.onerror=rej; reader.readAsBinaryString(file);
  });
}

// ── RECONCILIATION ────────────────────────────────────────────
async function runRecon() {
  const tbody = document.getElementById('reconTableBody');
  tbody.innerHTML = `<tr><td colspan="9" style="text-align:center;padding:30px;"><span class="loading-spinner"></span> Running reconciliation...</td></tr>`;
  try {
    const { data:orders, error:oErr } = await db.from('cod_orders').select('*').order('order_date',{ascending:false});
    if (oErr) throw oErr;
    const { data:settlements, error:sErr } = await db.from('cod_settlements').select('*');
    if (sErr) throw sErr;

    // Build settlement lookup: by order_id and by email (for BillDesk)
    const settleById = {}, settleByEmail = {};
    (settlements||[]).forEach(s => {
      const k = s.platform+'::'+s.order_id;
      if (!settleById[k]) settleById[k] = {total:0, settlement_id:s.settlement_id, utr:s.utr_number};
      settleById[k].total += parseFloat(s.settled_amount||0);
      // BillDesk email fallback — if order_id looks like email
      if (s.platform==='billdesk' && s.order_id && s.order_id.includes('@')) {
        const ek = 'billdesk::email::'+s.order_id.toLowerCase();
        if (!settleByEmail[ek]) settleByEmail[ek] = {total:0, settlement_id:s.settlement_id, utr:s.utr_number};
        settleByEmail[ek].total += parseFloat(s.settled_amount||0);
      }
    });

    const reconRows = [], statusUpdates = [];
    (orders||[]).forEach(o => {
      let settle = settleById[o.platform+'::'+o.order_id];
      if (!settle && o.platform==='billdesk' && o.email)
        settle = settleByEmail['billdesk::email::'+o.email.toLowerCase()];
      const saleAmt = parseFloat(o.sale_amount||0);
      const settledAmt = settle ? settle.total : 0;
      const pendingAmt = Math.max(0, saleAmt - settledAmt);
      const newStatus = (settle && Math.abs(saleAmt - settledAmt) < 1) ? 'settled' : 'pending';
      reconRows.push({ ...o, settled_amount:settledAmt, pending_amt:pendingAmt, status:newStatus, settlement_id:settle?.settlement_id||'', utr:settle?.utr||'' });
      if (o.status !== newStatus) statusUpdates.push({id:o.id, status:newStatus});
    });

    // Bulk update statuses
    for (const u of statusUpdates) await db.from('cod_orders').update({status:u.status}).eq('id',u.id);

    reconData = reconRows;
    reconPage = 1;
    applyReconFilters();
    loadDashboard();
  } catch(err) {
    tbody.innerHTML = `<tr><td colspan="9" style="text-align:center;color:var(--red);padding:30px;">Error: ${err.message}</td></tr>`;
  }
}

