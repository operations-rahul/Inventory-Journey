function renderReconPagination() {
  const total = reconFiltered.length, pages = Math.ceil(total/PAGE_SIZE);
  const pg = document.getElementById('reconPagination');
  if (pages<=1) { pg.innerHTML=`<span style="font-size:12px;color:var(--text2);">${total} records</span>`; return; }
  let html = `<span style="font-size:12px;color:var(--text2);margin-right:8px;">${total} records</span>`;
  html += `<button class="pg-btn" onclick="pgGo(${reconPage-1})" ${reconPage===1?'disabled':''}>‹</button>`;
  for (let i=1;i<=pages;i++) {
    if (i===1||i===pages||Math.abs(i-reconPage)<=2) html+=`<button class="pg-btn ${i===reconPage?'active':''}" onclick="pgGo(${i})">${i}</button>`;
    else if(Math.abs(i-reconPage)===3) html+='<span style="padding:0 4px;color:#aaa;">…</span>';
  }
  html += `<button class="pg-btn" onclick="pgGo(${reconPage+1})" ${reconPage===pages?'disabled':''}>›</button>`;
  pg.innerHTML = html;
}
function pgGo(p) { reconPage=p; renderReconTable(); renderReconPagination(); window.scrollTo(0,300); }

