<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TRINETRA – COD Reconciliation</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
<style>
:root{--cream:#fdf6ec;--cream2:#f7ede0;--gold:#c9a84c;--gold2:#e0bf6e;--gold-dark:#8a6a1f;--brown:#5c3d1e;--text:#2c1a0e;--text2:#6b4c2a;--border:#e0cba0;--white:#fff;--red:#c0392b;--green:#27ae60;--orange:#e67e22;--blue:#2980b9;--shadow:0 4px 24px rgba(90,60,10,.10)}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--cream);font-family:'Inter',sans-serif;color:var(--text);min-height:100vh}

/* HEADER */
.header{background:linear-gradient(135deg,var(--brown) 0%,#3a2510 100%);padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 4px 16px rgba(90,60,10,.25);position:sticky;top:0;z-index:300}
.logo-text{font-family:'Playfair Display',serif;color:var(--gold2);font-size:22px;letter-spacing:2px}
.logo-sub{color:#c9a84c88;font-size:11px;letter-spacing:3px;text-transform:uppercase;margin-top:2px}
.conn-badge{display:flex;align-items:center;gap:6px;background:rgba(201,168,76,.12);border:1px solid var(--gold);border-radius:20px;padding:4px 14px;font-size:12px;color:var(--gold2)}
.conn-dot{width:8px;height:8px;border-radius:50%;background:#aaa}
.conn-dot.online{background:#27ae60;box-shadow:0 0 6px #27ae60;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}

/* LAYOUT */
.app-body{display:flex;min-height:calc(100vh - 64px)}
.sidebar{width:220px;min-width:220px;background:linear-gradient(180deg,#3a2510 0%,var(--brown) 100%);padding:24px 0 32px;display:flex;flex-direction:column;gap:4px;position:sticky;top:64px;height:calc(100vh - 64px);overflow-y:auto;box-shadow:4px 0 18px rgba(90,60,10,.12)}
.sidebar-label{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#c9a84c55;padding:0 20px 8px;margin-top:8px}
.nav-item{display:flex;align-items:center;gap:12px;padding:12px 20px;cursor:pointer;color:#d4b896;font-size:13px;font-weight:500;border-left:3px solid transparent;transition:all .2s;white-space:nowrap;user-select:none}
.nav-item:hover{background:rgba(255,255,255,.08);color:#fff}
.nav-item.active{background:rgba(201,168,76,.18);color:#f0d080;border-left-color:var(--gold);font-weight:600}
.nav-icon{font-size:16px;width:20px;text-align:center;flex-shrink:0}
.main-area{flex:1;overflow-x:hidden}
.content{padding:28px 32px;max-width:1200px}
.page{display:none}
.page.active{display:block}
.sidebar-toggle{display:none;background:none;border:none;cursor:pointer;color:var(--gold2);font-size:22px;padding:4px 8px}
@media(max-width:768px){
  .sidebar{position:fixed;left:-220px;top:0;height:100vh;z-index:200;transition:left .25s}
  .sidebar.open{left:0}
  .sidebar-toggle{display:block}
  .main-area{width:100%}
  .content{padding:16px}
  .sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:199}
  .sidebar-overlay.open{display:block}
  .form-grid{grid-template-columns:1fr}
}

/* CARDS */
.cards-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:16px;margin-bottom:20px}
.card{background:var(--white);border-radius:14px;padding:18px 16px;border:1px solid var(--border);box-shadow:var(--shadow);display:flex;flex-direction:column;gap:6px}
.card-label{font-size:11px;text-transform:uppercase;letter-spacing:1.5px;color:var(--text2)}
.card-value{font-family:'Playfair Display',serif;font-size:24px;color:var(--brown)}
.card-value.red{color:var(--red)}
.card-value.green{color:var(--green)}
.card-value.orange{color:var(--orange)}

/* SECTION */
.sec-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:10px}
.sec-title{font-family:'Playfair Display',serif;font-size:18px;color:var(--brown)}

/* UPLOAD */
.upload-card{background:var(--white);border-radius:14px;padding:24px;border:1px solid var(--border);box-shadow:var(--shadow)}
.upload-card h3{font-size:14px;font-weight:600;color:var(--brown);margin-bottom:14px;display:flex;align-items:center;gap:8px}
.plat-icon{width:24px;height:24px;border-radius:6px;display:inline-flex;align-items:center;justify-content:center;font-size:11px;font-weight:700}
.plat-del{background:#e74c3c;color:#fff}
.plat-blu{background:#1565c0;color:#fff}
.plat-bds{background:#6a1b9a;color:#fff}
.plat-snp{background:#00897b;color:#fff}
.plat-zip{background:#f57c00;color:#fff}
.drop-zone{border:2px dashed var(--border);border-radius:10px;padding:20px;text-align:center;cursor:pointer;transition:all .2s;background:var(--cream);color:var(--text2);font-size:13px;position:relative}
.drop-zone:hover,.drop-zone.drag{border-color:var(--gold);background:rgba(201,168,76,.07)}
.drop-zone input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%}
.drop-icon{font-size:24px;margin-bottom:6px}
.drop-label{font-weight:500;font-size:12px}
.drop-sub{font-size:11px;color:#aaa;margin-top:4px}
.file-list{margin-top:10px;display:flex;flex-direction:column;gap:4px}
.file-item{background:var(--cream);border-radius:6px;padding:6px 10px;font-size:12px;color:var(--text);display:flex;align-items:center;justify-content:space-between;border:1px solid var(--border)}
.file-item .status.ok{color:var(--green)}
.file-item .status.err{color:var(--red)}
.file-item .status.loading{color:var(--orange)}
.upload-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px}

/* BUTTONS */
.btn{padding:9px 20px;border-radius:8px;border:none;cursor:pointer;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;transition:all .2s}
.btn-gold{background:linear-gradient(135deg,var(--gold) 0%,var(--gold2) 100%);color:var(--brown);box-shadow:0 2px 8px rgba(201,168,76,.3)}
.btn-gold:hover{transform:translateY(-1px);box-shadow:0 4px 12px rgba(201,168,76,.4)}
.btn-outline{background:transparent;border:1.5px solid var(--gold);color:var(--gold-dark)}
.btn-outline:hover{background:rgba(201,168,76,.1)}
.btn-red{background:#fdecea;color:var(--red);border:1px solid #f5c6c2}
.btn-sm{padding:5px 12px;font-size:12px;border-radius:6px}

/* FILTERS */
.filters{display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:18px}
.filter-select,.filter-input{padding:8px 12px;border:1.5px solid var(--border);border-radius:8px;font-family:'Inter',sans-serif;font-size:13px;background:var(--white);color:var(--text);outline:none}
.filter-select:focus,.filter-input:focus{border-color:var(--gold)}

/* TABLE */
.table-wrap{overflow-x:auto;border-radius:12px;box-shadow:var(--shadow)}
table{width:100%;border-collapse:collapse;background:var(--white);font-size:13px}
thead tr{background:linear-gradient(135deg,var(--brown) 0%,#4a2e15 100%)}
thead th{padding:12px 14px;text-align:left;color:var(--gold2);font-weight:500;font-size:12px;letter-spacing:.5px;white-space:nowrap}
tbody tr{border-bottom:1px solid var(--cream2);transition:background .15s}
tbody tr:hover{background:var(--cream)}
tbody td{padding:10px 14px;vertical-align:middle}
.badge{display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600}
.badge-settled{background:#d5f5e3;color:#1e8449}
.badge-pending{background:#fef9e7;color:#b7770d}

/* PILLS */
.plat-pills{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px}
.plat-pill{padding:5px 14px;border-radius:20px;border:1.5px solid var(--border);font-size:12px;cursor:pointer;transition:all .2s;background:var(--white);color:var(--text2);font-weight:500}
.plat-pill.active{border-color:var(--gold);background:rgba(201,168,76,.12);color:var(--gold-dark)}

/* SUMMARY TABLE */
.summary-table{width:100%;border-collapse:collapse;font-size:13px}
.summary-table th{padding:10px 14px;text-align:left;background:var(--cream2);color:var(--text2);font-weight:600;font-size:12px;border-bottom:2px solid var(--border)}
.summary-table td{padding:10px 14px;border-bottom:1px solid var(--cream2)}
.summary-table tr:last-child td{border-bottom:none;font-weight:600;background:var(--cream)}

/* TOAST */
.toast-container{position:fixed;bottom:24px;right:24px;display:flex;flex-direction:column;gap:8px;z-index:9999}
.toast{padding:12px 20px;border-radius:10px;font-size:13px;font-weight:500;box-shadow:0 4px 16px rgba(0,0,0,.15);animation:fadeInUp .3s ease;max-width:320px}
.toast.success{background:#d5f5e3;color:#1e8449;border:1px solid #a9dfbf}
.toast.error{background:#fdecea;color:var(--red);border:1px solid #f5b7b1}
.toast.info{background:#eaf4fd;color:#1a6ea3;border:1px solid #a9cce3}
@keyframes fadeInUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:500;align-items:center;justify-content:center}
.modal-overlay.open{display:flex}
.modal{background:var(--white);border-radius:16px;padding:28px;width:90%;max-width:600px;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.2)}
.modal-title{font-family:'Playfair Display',serif;font-size:20px;color:var(--brown);margin-bottom:18px}
.modal-close{float:right;cursor:pointer;color:var(--text2);font-size:20px;background:none;border:none}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.form-group{display:flex;flex-direction:column;gap:5px}
.form-group label{font-size:12px;color:var(--text2);font-weight:500}
.form-group input,.form-group select{padding:9px 12px;border:1.5px solid var(--border);border-radius:8px;font-family:'Inter',sans-serif;font-size:13px;background:var(--white);outline:none}
.form-group input:focus,.form-group select:focus{border-color:var(--gold)}

/* PAGINATION */
.pagination{display:flex;gap:6px;align-items:center;justify-content:flex-end;margin-top:14px}
.pg-btn{padding:5px 12px;border-radius:6px;border:1.5px solid var(--border);background:var(--white);cursor:pointer;font-size:12px;color:var(--text)}
.pg-btn.active{background:var(--gold);color:var(--brown);border-color:var(--gold);font-weight:600}
.pg-btn:disabled{opacity:.4;cursor:default}
.empty-state{text-align:center;padding:48px 20px;color:var(--text2)}
.empty-icon{font-size:40px;margin-bottom:10px}
.empty-text{font-size:14px}
.loading-spinner{display:inline-block;width:16px;height:16px;border:2px solid var(--gold);border-top-color:transparent;border-radius:50%;animation:spin .7s linear infinite;vertical-align:middle;margin-right:6px}
@keyframes spin{to{transform:rotate(360deg)}}
</style>
</head>
<body>

<div class="header">
  <div style="display:flex;align-items:center;gap:14px;">
    <button class="sidebar-toggle" onclick="toggleSidebar()">☰</button>
    <div>
      <div class="logo-text">TRINETRA</div>
      <div class="logo-sub">COD Reconciliation</div>
    </div>
  </div>
  <div class="conn-badge">
    <div class="conn-dot" id="connDot"></div>
    <span id="connStatus">Connecting...</span>
  </div>
</div>

<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<div class="app-body">
<nav class="sidebar" id="sidebar">
  <div class="sidebar-label">Navigation</div>
  <div class="nav-item active" data-tab="dashboard"><span class="nav-icon">📊</span> Dashboard</div>
  <div class="nav-item" data-tab="orders"><span class="nav-icon">🛒</span> Orders Upload</div>
  <div class="nav-item" data-tab="settlement"><span class="nav-icon">💰</span> Settlement Upload</div>
  <div class="nav-item" data-tab="recon"><span class="nav-icon">🔍</span> Reconciliation</div>
  <div class="nav-item" data-tab="history"><span class="nav-icon">📋</span> History</div>
  <div style="margin-top:auto;padding-top:24px;border-top:1px solid rgba(201,168,76,.15);margin:24px 12px 0"></div>
  <div class="nav-item" data-tab="backup"><span class="nav-icon">🗄️</span> Backup & Restore</div>
</nav>

<div class="main-area">
<div class="content">

<!-- ====== DASHBOARD ====== -->
<div class="page active" id="page-dashboard">
  <div class="cards-row">
    <div class="card"><div class="card-label">Total Orders</div><div class="card-value" id="sc-total">—</div></div>
    <div class="card"><div class="card-label">Settled</div><div class="card-value green" id="sc-settled">—</div></div>
    <div class="card"><div class="card-label">Pending</div><div class="card-value orange" id="sc-pending">—</div></div>
    <div class="card"><div class="card-label">Total Sale Amt</div><div class="card-value" id="sc-saleamt">—</div></div>
    <div class="card"><div class="card-label">Settled Amt</div><div class="card-value green" id="sc-settledamt">—</div></div>
    <div class="card"><div class="card-label">Pending Amt</div><div class="card-value red" id="sc-pendingamt">—</div></div>
  </div>

  <div style="background:var(--white);border-radius:14px;padding:20px;border:1px solid var(--border);box-shadow:var(--shadow);margin-bottom:20px;">
    <div class="sec-header">
      <div class="sec-title">Platform-wise Summary</div>
      <button class="btn btn-outline btn-sm" onclick="loadDashboard()">↺ Refresh</button>
    </div>
    <div style="overflow-x:auto;">
      <table class="summary-table">
        <thead><tr>
          <th>Platform</th><th>Orders</th><th>Sale Amt (₹)</th>
          <th>Settled Amt (₹)</th><th>Pending Amt (₹)</th><th>Settled</th><th>Pending</th><th>Action</th>
        </tr></thead>
        <tbody id="platformSummaryBody"><tr><td colspan="8" style="text-align:center;padding:30px;color:#aaa;">Loading...</td></tr></tbody>
      </table>
    </div>
  </div>

  <!-- DRILLDOWN -->
  <div style="background:var(--white);border-radius:14px;padding:20px;border:1px solid var(--border);box-shadow:var(--shadow);">
    <div class="sec-header">
      <div class="sec-title" id="drillTitle">💸 Pending Orders — Select Platform Above</div>
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <button class="btn btn-gold btn-sm" id="drillExportBtn" onclick="exportDrilldown()" style="display:none;">⬇ Export</button>
      </div>
    </div>
    <div style="margin-bottom:12px;">
      <input class="filter-input" type="text" id="drillSearch" placeholder="Order ID ya email search..." oninput="applyDrillFilters()" style="width:100%;max-width:320px;">
    </div>
    <div id="drillEmptyMsg" style="text-align:center;padding:32px;color:#aaa;font-size:13px;">
      <div style="font-size:32px;margin-bottom:8px;">👆</div>
      Platform summary mein <b>View Pending</b> button dabao
    </div>
    <div id="drillTableWrap" style="display:none;overflow-x:auto;">
      <table>
        <thead><tr>
          <th>Order ID</th><th>Order Date</th><th>Email</th>
          <th>Sale Amt (₹)</th><th>Settled Amt (₹)</th><th>Pending Amt (₹)</th><th>Status</th>
        </tr></thead>
        <tbody id="drillTableBody"></tbody>
      </table>
      <div style="margin-top:10px;display:flex;justify-content:space-between;align-items:center;font-size:12px;color:var(--text2);">
        <span id="drillCount"></span>
        <span id="drillTotalDue" style="font-weight:600;color:var(--red);"></span>
      </div>
    </div>
  </div>
</div>

<!-- ====== ORDERS UPLOAD ====== -->
<div class="page" id="page-orders">
  <div class="sec-header">
    <div class="sec-title">Upload Sales / Orders</div>
    <button class="btn btn-gold btn-sm" onclick="openManualOrder()">+ Manual Entry</button>
  </div>
  <div class="upload-card" style="margin-bottom:20px;">
    <h3 style="margin-bottom:6px;">📦 Bulk Upload — BUSY Dispatch Sheet</h3>
    <p style="font-size:12px;color:var(--text2);margin-bottom:4px;">BUSY dispatch sheet directly upload karo. Platform <b>Column A</b> se auto-detect hoga:</p>
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin:10px 0 14px;">
      <span style="font-size:11px;background:var(--cream);border:1px solid var(--border);padding:3px 10px;border-radius:12px;">BILLDESK</span>
      <span style="font-size:11px;background:var(--cream);border:1px solid var(--border);padding:3px 10px;border-radius:12px;">CODDEL</span>
      <span style="font-size:11px;background:var(--cream);border:1px solid var(--border);padding:3px 10px;border-radius:12px;">CODBLUE</span>
      <span style="font-size:11px;background:var(--cream);border:1px solid var(--border);padding:3px 10px;border-radius:12px;">SNAPMINT</span>
      <span style="font-size:11px;background:var(--cream);border:1px solid var(--border);padding:3px 10px;border-radius:12px;">CODZIPPIE</span>
    </div>
    <div class="drop-zone" id="dz-bulk-orders" ondragover="dzDrag(event,'dz-bulk-orders')" ondragleave="dzLeave('dz-bulk-orders')" ondrop="dzDropBulk(event)">
      <input type="file" accept=".csv,.xlsx,.xls" id="bulkOrderInput" onchange="handleBulkFile(this)">
      <div class="drop-icon">📂</div>
      <div class="drop-label">BUSY Dispatch Sheet drop karo ya click karo</div>
      <div class="drop-sub">CSV / XLSX</div>
    </div>
    <div class="file-list" id="fl-bulk-orders"></div>
    <div id="bulkPreview" style="display:none;margin-top:14px;">
      <div id="bulkPreviewInfo" style="font-size:12px;padding:12px;background:var(--cream);border-radius:8px;border:1px solid var(--border);margin-bottom:10px;line-height:1.8;"></div>
      <button class="btn btn-gold" style="width:100%" onclick="confirmBulkUpload()">✅ Import Karo</button>
      <button class="btn btn-outline" style="width:100%;margin-top:8px;" onclick="cancelBulkUpload()">Cancel</button>
    </div>
  </div>
  <div style="background:var(--white);border-radius:12px;padding:16px;border:1px solid var(--border);font-size:12px;color:var(--text2);">
    <b style="color:var(--brown);">Expected Columns:</b> A: Platform | B: Date | E: Order ID | K: Email | P: Selling Amount — <i>Multiple rows same Order ID = sum ho jayega</i>
  </div>
</div>

<!-- ====== SETTLEMENT UPLOAD ====== -->
<div class="page" id="page-settlement">
  <div class="sec-header"><div class="sec-title">Upload Settlement Files</div></div>
  <p style="font-size:13px;color:var(--text2);margin-bottom:20px;">Courier / payment partner ne jo remittance file bheji hai usse yahan upload karo.</p>
  <div class="upload-grid">
    <div class="upload-card">
      <h3><span class="plat-icon plat-del">D</span> Delhivery Settlement</h3>
      <div style="font-size:12px;color:var(--text2);margin-bottom:10px;">Delhivery COD remittance report</div>
      <div class="drop-zone" id="dz-delhivery-settle" ondragover="dzDrag(event,'dz-delhivery-settle')" ondragleave="dzLeave('dz-delhivery-settle')" ondrop="dzDrop(event,'delhivery','settlement')">
        <input type="file" accept=".csv,.xlsx,.xls,.txt" onchange="handleFile(this,'delhivery','settlement')">
        <div class="drop-icon">💰</div><div class="drop-label">Settlement file drop karo</div><div class="drop-sub">CSV / XLSX</div>
      </div>
      <div class="file-list" id="fl-delhivery-settle"></div>
    </div>
    <div class="upload-card">
      <h3><span class="plat-icon plat-blu">B</span> Bluedart Settlement</h3>
      <div style="font-size:12px;color:var(--text2);margin-bottom:10px;">Bluedart COD remittance report</div>
      <div class="drop-zone" id="dz-bluedart-settle" ondragover="dzDrag(event,'dz-bluedart-settle')" ondragleave="dzLeave('dz-bluedart-settle')" ondrop="dzDrop(event,'bluedart','settlement')">
        <input type="file" accept=".csv,.xlsx,.xls" onchange="handleFile(this,'bluedart','settlement')">
        <div class="drop-icon">💰</div><div class="drop-label">Settlement file drop karo</div><div class="drop-sub">CSV / XLSX</div>
      </div>
      <div class="file-list" id="fl-bluedart-settle"></div>
    </div>
    <div class="upload-card">
      <h3><span class="plat-icon plat-bds">BD</span> BillDesk Settlement</h3>
      <div style="font-size:12px;color:var(--text2);margin-bottom:10px;">BillDesk payment settlement (email se match hoga)</div>
      <div class="drop-zone" id="dz-billdesk-settle" ondragover="dzDrag(event,'dz-billdesk-settle')" ondragleave="dzLeave('dz-billdesk-settle')" ondrop="dzDrop(event,'billdesk','settlement')">
        <input type="file" accept=".csv,.xlsx,.xls" onchange="handleFile(this,'billdesk','settlement')">
        <div class="drop-icon">💰</div><div class="drop-label">Settlement file drop karo</div><div class="drop-sub">CSV / XLSX</div>
      </div>
      <div class="file-list" id="fl-billdesk-settle"></div>
    </div>
    <div class="upload-card">
