  const { error } = await db.from('cod_orders').upsert({platform,order_id,order_date,email,sale_amount,payment_type:'COD',status:'pending'},{onConflict:'platform, order_id'});
  if (error) { showToast('Save failed: '+error.message,'error'); return; }
  showToast('✅ Order saved!','success');
  closeManualOrder();
  loadDashboard();
}

// ── BACKUP & RESTORE ──────────────────────────────────────────
async function loadBackupStats() {
  const el = document.getElementById('backupStats');
  if (!el) return;
  try {
    const [o,s,l] = await Promise.all([
      db.from('cod_orders').select('id',{count:'exact',head:true}),
      db.from('cod_settlements').select('id',{count:'exact',head:true}),
      db.from('cod_upload_log').select('id',{count:'exact',head:true}),
    ]);
    el.innerHTML=`<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;text-align:center;">
      <div><div style="font-size:20px;font-weight:700;color:var(--brown);">${o.count||0}</div><div>Orders</div></div>
      <div><div style="font-size:20px;font-weight:700;color:var(--brown);">${s.count||0}</div><div>Settlements</div></div>
      <div><div style="font-size:20px;font-weight:700;color:var(--brown);">${l.count||0}</div><div>Logs</div></div>
    </div>`;
  } catch(e) { el.innerHTML='<span style="color:var(--red)">Stats load nahi hua</span>'; }
}
async function downloadBackup() {
  showToast('Backup prepare ho raha hai...','info');
  try {
    const [o,s,l] = await Promise.all([db.from('cod_orders').select('*'),db.from('cod_settlements').select('*'),db.from('cod_upload_log').select('*')]);
    if (o.error) throw o.error;
    const backup = {version:'1.0',exported_at:new Date().toISOString(),tables:{cod_orders:o.data||[],cod_settlements:s.data||[],cod_upload_log:l.data||[]}};
    const blob = new Blob([JSON.stringify(backup,null,2)],{type:'application/json'});
    const url = URL.createObjectURL(blob); const a = document.createElement('a');
    a.href=url; a.download='cod_backup_'+new Date().toISOString().slice(0,10)+'.json'; a.click(); URL.revokeObjectURL(url);
    showToast('✅ Backup download ho gaya','success');
  } catch(err) { showToast('Backup failed: '+err.message,'error'); }
}
function handleRestoreFile(input) {
  if (!input.files.length) return;
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const data = JSON.parse(e.target.result);
      if (!data.tables||!data.tables.cod_orders) throw new Error('Invalid backup file');
      _restoreData = data;
      const o=(data.tables.cod_orders||[]).length, s=(data.tables.cod_settlements||[]).length;
      document.getElementById('restoreInfo').innerHTML=`Backup: <b>${data.exported_at?new Date(data.exported_at).toLocaleString('en-IN'):'Unknown'}</b><br>Orders: <b>${o}</b> | Settlements: <b>${s}</b>`;
      document.getElementById('restorePreview').style.display='block';
      addFileItem('restore', input.files[0].name, 'ok', 'Ready to restore');
    } catch(err) { addFileItem('restore', input.files[0].name, 'err', err.message); showToast('Invalid file!','error'); }
  };
  reader.readAsText(input.files[0]);
}
function dzDropRestore(e) { e.preventDefault(); dzLeave('dz-restore'); if(e.dataTransfer.files.length) handleRestoreFile({files:e.dataTransfer.files}); }
function cancelRestore() { _restoreData=null; document.getElementById('restorePreview').style.display='none'; document.getElementById('restoreFileInput').value=''; document.getElementById('fl-restore').innerHTML=''; }
function confirmRestore() {
  if (!_restoreData) return;
  showConfirm('Restore Confirm',`${(_restoreData.tables.cod_orders||[]).length} orders restore honge. Duplicates skip honge. Continue?`,'✅ Restore Karo','btn-gold',()=>doRestore());
}
async function doRestore() {
  if (!_restoreData) return;
  showToast('Restore ho raha hai...','info');
  try {
    const orders=_restoreData.tables.cod_orders||[], settlements=_restoreData.tables.cod_settlements||[], logs=_restoreData.tables.cod_upload_log||[];
    for (let i=0;i<orders.length;i+=200) { const {error}=await db.from('cod_orders').upsert(orders.slice(i,i+200),{onConflict:'platform, order_id',ignoreDuplicates:true}); if(error) throw error; }
    for (let i=0;i<settlements.length;i+=200) { const {error}=await db.from('cod_settlements').upsert(settlements.slice(i,i+200),{onConflict:'platform, order_id, settlement_id',ignoreDuplicates:true}); if(error) throw error; }
    for (let i=0;i<logs.length;i+=200) { await db.from('cod_upload_log').upsert(logs.slice(i,i+200),{ignoreDuplicates:true}); }
    showToast('✅ Restore complete!','success'); cancelRestore(); loadBackupStats(); loadDashboard();
  } catch(err) { showToast('Restore failed: '+err.message,'error'); }
}
function confirmDeleteAll(what) {
  const msgs={orders:'Saare ORDERS permanently delete ho jayenge!',settlements:'Saare SETTLEMENTS permanently delete ho jayenge!',all:'POORA DATA permanently delete ho jayega!'};
  showConfirm('⚠️ Are you sure?',msgs[what]+' Pehle backup lo!','🗑 Delete Karo','btn-red',()=>deleteAll(what));
}
async function deleteAll(what) {
  try {
    const dummy='00000000-0000-0000-0000-000000000000';
    if(what==='orders'||what==='all') { const {error}=await db.from('cod_orders').delete().neq('id',dummy); if(error) throw error; }
    if(what==='settlements'||what==='all') { const {error}=await db.from('cod_settlements').delete().neq('id',dummy); if(error) throw error; }
    if(what==='all') { await db.from('cod_upload_log').delete().neq('id',dummy); }
    showToast('✅ Data delete ho gaya','success'); loadDashboard(); loadBackupStats();
  } catch(err) { showToast('Delete failed: '+err.message,'error'); }
}

// ── HELPERS ───────────────────────────────────────────────────
function addFileItem(key, name, status, msg) {
  const listEl = document.getElementById('fl-'+key);
  if (!listEl) return;
  const id = 'fi-'+key+'-'+name.replace(/\W/g,'_');
  let el = document.getElementById(id);
  if (!el) { el=document.createElement('div'); el.className='file-item'; el.id=id; listEl.appendChild(el); }
  const icon = status==='ok'?'✅':status==='err'?'❌':'⏳';
  el.innerHTML = `<span style="font-size:11px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:160px;" title="${name}">${name}</span><span class="status ${status}">${icon} ${msg}</span>`;
}
function fmt(n) { return parseFloat(n||0).toLocaleString('en-IN',{minimumFractionDigits:2,maximumFractionDigits:2}); }
function fmtK(n) { n=parseFloat(n||0); if(n>=100000) return (n/100000).toFixed(1)+'L'; if(n>=1000) return (n/1000).toFixed(1)+'K'; return fmt(n); }
function platBadge(p) {
  const m={delhivery:'plat-del',bluedart:'plat-blu',billdesk:'plat-bds',snapmint:'plat-snp',zippie:'plat-zip'};
  const l={delhivery:'Delhivery',bluedart:'Bluedart',billdesk:'BillDesk',snapmint:'Snapmint',zippie:'Zippie',bulk:'Bulk'};
  return `<span class="plat-icon ${m[p]||'plat-del'}" style="border-radius:4px;padding:2px 6px;font-size:11px;">${l[p]||p}</span>`;
}
function parseDate(v) {
  if (!v) return null;
  const num = typeof v==='number' ? v : (/^\d{4,6}$/.test(String(v).trim()) ? parseInt(v) : null);
  if (num && num>40000 && num<60000) { const d=new Date((num-25569)*86400*1000); if(!isNaN(d)) return d.toISOString().slice(0,10); }
  if (v instanceof Date) return isNaN(v)?null:v.toISOString().slice(0,10);
  const s = String(v).trim();
  if (!s||s==='Invalid Date') return null;
  let m = s.match(/^(\d{2})[\/\-](\d{2})[\/\-](\d{4})/); if(m) return `${m[3]}-${m[2]}-${m[1]}`;
  m = s.match(/^(\d{4})-(\d{2})-(\d{2})/); if(m) return `${m[1]}-${m[2]}-${m[3]}`;
  m = s.match(/^(\d{2})-([A-Za-z]{3})-(\d{2,4})$/);
  if (m) { const mo={jan:'01',feb:'02',mar:'03',apr:'04',may:'05',jun:'06',jul:'07',aug:'08',sep:'09',oct:'10',nov:'11',dec:'12'}; const mn=mo[m[2].toLowerCase()]||'01'; const yr=m[3].length===2?'20'+m[3]:m[3]; return `${yr}-${mn}-${m[1]}`; }
  const d=new Date(s); if(!isNaN(d)) return d.toISOString().slice(0,10); return null;
}
function showToast(msg, type='info') {
  const c=document.getElementById('toastContainer'); const t=document.createElement('div');
  t.className='toast '+type; t.textContent=msg; c.appendChild(t); setTimeout(()=>t.remove(),3500);
}
