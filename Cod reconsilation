async function saveManualOrder() {
  const platform=document.getElementById('mo-platform').value;
  const order_id=document.getElementById('mo-orderid').value.trim();
  const order_date=document.getElementById('mo-date').value||null;
  const email=document.getElementById('mo-email').value.trim()||null;
