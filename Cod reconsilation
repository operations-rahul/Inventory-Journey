async function loadDashboard() {
  try {
    const { data, error } = await db.from('cod_orders').select('platform,sale_amount,status');
    if (error) throw error;
    const total = data.length;
    const settled = data.filter(r=>r.status==='settled').length;
    const pending = data.filter(r=>r.status==='pending').length;
    const totalAmt = data.reduce((s,r)=>s+parseFloat(r.sale_amount||0),0);
    const { data:sData } = await db.from('cod_settlements').select('platform,settled_amount');
    const settledAmt = (sData||[]).reduce((s,r)=>s+parseFloat(r.settled_amount||0),0);
    const pendingAmt = Math.max(0, totalAmt-settledAmt);
    document.getElementById('sc-total').textContent = total;
    document.getElementById('sc-settled').textContent = settled;
    document.getElementById('sc-pending').textContent = pending;
    document.getElementById('sc-saleamt').textContent = '₹'+fmtK(totalAmt);
    document.getElementById('sc-settledamt').textContent = '₹'+fmtK(settledAmt);
    document.getElementById('sc-pendingamt').textContent = '₹'+fmtK(pendingAmt);

    const plats = ['delhivery','bluedart','billdesk','snapmint','zippie'];
    const ps = {};
    plats.forEach(p => ps[p]={orders:0,saleAmt:0,settled:0,pending:0});
    data.forEach(r => {
      const p=r.platform||'other';
      if(!ps[p]) ps[p]={orders:0,saleAmt:0,settled:0,pending:0};
      ps[p].orders++; ps[p].saleAmt+=parseFloat(r.sale_amount||0);
      if(r.status==='settled') ps[p].settled++; else ps[p].pending++;
    });
    const platSettle = {};
    (sData||[]).forEach(r=>{ const p=r.platform||'other'; platSettle[p]=(platSettle[p]||0)+parseFloat(r.settled_amount||0); });

    const tbody = document.getElementById('platformSummaryBody');
    const rows = Object.entries(ps).filter(([,v])=>v.orders>0);
    if (!rows.length) { tbody.innerHTML=`<tr><td colspan="8" style="text-align:center;padding:30px;color:#aaa;">Koi data nahi. Orders upload karo.</td></tr>`; return; }
    let tO=0,tS=0,tSt=0,tSe=0,tP=0;
    tbody.innerHTML = rows.map(([p,v])=>{
      const sa=platSettle[p]||0, pa=Math.max(0,v.saleAmt-sa);
      tO+=v.orders; tS+=v.saleAmt; tSt+=sa; tSe+=v.settled; tP+=v.pending;
      return `<tr>
        <td>${platBadge(p)}</td><td>${v.orders}</td>
        <td style="text-align:right;">₹${fmt(v.saleAmt)}</td>
        <td style="text-align:right;color:var(--green);">₹${fmt(sa)}</td>
        <td style="text-align:right;color:var(--red);font-weight:600;">₹${fmt(pa)}</td>
        <td><span class="badge badge-settled">${v.settled}</span></td>
        <td><span class="badge badge-pending">${v.pending}</span></td>
        <td><button class="btn btn-outline btn-sm" onclick="loadDrilldown('${p}')" style="white-space:nowrap;">🔍 View Pending</button></td>
      </tr>`;
    }).join('') + `<tr style="background:var(--cream);font-weight:600;">
      <td>TOTAL</td><td>${tO}</td>
      <td style="text-align:right;">₹${fmt(tS)}</td>
      <td style="text-align:right;color:var(--green);">₹${fmt(tSt)}</td>
      <td style="text-align:right;color:var(--red);">₹${fmt(Math.max(0,tS-tSt))}</td>
      <td><span class="badge badge-settled">${tSe}</span></td>
      <td><span class="badge badge-pending">${tP}</span></td>
      <td><button class="btn btn-outline btn-sm" onclick="loadDrilldown('all')" style="white-space:nowrap;">🔍 All Pending</button></td>
    </tr>`;
  } catch(err) { showToast('Dashboard error: '+err.message,'error'); }
}

